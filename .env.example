# Server Configuration
PORT=8005
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb://127.0.0.1:27017/attendsync

# JWT Configuration
JWT_SECRET=your_jwt_secret_here

# Nodemailer Configuration
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Frontend URL
FRONTEND_URL=http://localhost:5173

# CORS Configuration (comma separated list of allowed domains)
ALLOWED_ORIGINS=http://localhost:3000, http://localhost:8000, http://localhost:8081, https://yourproductiondomain.com
